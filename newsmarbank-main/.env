# SmartPay Configuration Hub
# Generate your secret keys and deployment hooks here.

# --- Backend Config ---
# JWT_SECRET=your_secret_here
# MONGODB_URI=mongodb+srv://...

# --- Unified Deployment Hub ---
# Copy your Render "Deploy Hook" from Render Dashboard > Settings
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxxx...

# --- Frontend Config ---
VITE_API_URL=https://smartpay-api.onrender.com
# VERCEL_PROJECT_ID=... (Optional if you use Vercel CLI)
# VERCEL_ORG_ID=... (Optional if you use Vercel CLI)
